# ============================================================
# VARIABLES DE ENTORNO - AYCweb
# Copiar este archivo como .env.local y completar los valores.
# NUNCA commitear .env.local al repositorio.
#
# IMPORTANTE: Ninguna de estas variables usa el prefijo NEXT_PUBLIC_
# para evitar que se filtren al bundle del cliente (frontend).
# Solo deben ser accedidas desde Server Components, Route Handlers
# o Server Actions de Next.js.
# ============================================================

# ----------------------------------------------------------
# WhatsApp / Contacto
# ----------------------------------------------------------
# Número de WhatsApp de contacto (sin + ni espacios, con código de país)
WHATSAPP_NUMBER=

# ----------------------------------------------------------
# Servicios externos / Scraping
# ----------------------------------------------------------
# URL del endpoint de precios de combustible de PETROPAR
PETROPAR_PRICES_URL=

# ----------------------------------------------------------
# n8n — Automatizaciones y Webhooks
# ----------------------------------------------------------
# URL base de la instancia de n8n (self-hosted o cloud)
N8N_BASE_URL=
# Webhook principal de n8n para notificaciones y leads
N8N_WEBHOOK_URL=
# Webhook de n8n para cotizaciones B2B
N8N_WEBHOOK_COTIZACIONES_URL=

# ----------------------------------------------------------
# Supabase (Server-Side únicamente)
# ----------------------------------------------------------
# URL del proyecto Supabase (server-side)
SUPABASE_URL=
# Clave de servicio (service_role key) — NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=
# Clave anónima (anon key) — para uso server-side en Route Handlers
SUPABASE_ANON_KEY=
# Bucket de Storage donde se guardan los PDFs de cotizaciones (default: cotizaciones)
SUPABASE_COTIZACIONES_BUCKET=cotizaciones

# ----------------------------------------------------------
# Administración — HTTP Basic Auth (proxy.ts)
# ----------------------------------------------------------
# Usuario administrador para acceder a rutas protegidas:
#   /controlroom, /panel, /autoppto, /legales, /admin/*
ADMIN_USER=
# Contraseña administrador. Usar una cadena larga y aleatoria.
ADMIN_PASS=

# ----------------------------------------------------------
# Kapso — WhatsApp Business API
# ----------------------------------------------------------
# ID del número de teléfono registrado en Kapso/Meta (usar el SANDBOX en pruebas)
KAPSO_PHONE_NUMBER_ID=
# API key de Kapso (nunca exponer al cliente)
KAPSO_API_KEY=
# Host del Platform API de Kapso (sin /platform/v1). Lo usan los scripts y el CLI.
KAPSO_API_BASE_URL=https://api.kapso.ai
# provider_model_id para el nodo decide AI del workflow whatsapp-recepcion.
# Obtener con: node .agents/skills/automate-whatsapp/scripts/list-provider-models.js
KAPSO_DECIDE_MODEL_ID=