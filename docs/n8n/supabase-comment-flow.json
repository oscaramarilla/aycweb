    {
      "parameters": {
        "requestMethod": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "jsonParameters": true,
        "options": {},
        "headerParametersJson": "{\"Authorization\":\"Bearer {{$env.N8N_OPENAI_API_KEY}}\",\"Content-Type\":\"application/json\"}",
        "bodyParametersJson": "{\n  \"model\": \"{{$env.OPENAI_MODEL || 'gpt-4o-mini'}}\",\n  \"temperature\": 0.0,\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"Eres un clasificador y extractor. Recibirás un comentario en texto y debes devolver UNICAMENTE un JSON válido con estas claves: \\\n+{\\\n  \\\"label\\\": \\\"legit\\\" o \\\"spam\\\",\\\n  \\\"intent\\\": una de [\\\"compra\\\", \\\"duda_operativa\\\", \\\"soporte\\\", \\\"otro\\\"],\\\n  \\\"summary\\\": breve resumen del dolor/consulta (max 40 palabras)\\\n}\\\nNo agregues texto fuera del JSON.\"},\n    {\"role\": \"user\", \"content\": \"{{ $json[\\\"comment\\\"] }}\"}\n  ]\n}"
      },
      "name": "OpenAI - classify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [780, 300]
    },
    {
      "parameters": {
        "functionCode": "const body = $json; // OpenAI response object\nconst content = body.choices && body.choices[0] && body.choices[0].message && body.choices[0].message.content ? body.choices[0].message.content : null;\nlet parsed = { label: 'unknown', intent: 'otro', summary: '' };\nif (content) {\n  try {\n    parsed = JSON.parse(content);\n  } catch (e) {\n    // try to extract JSON substring\n    const m = content.match(/\\{[\\s\\S]*\\}/);\n    if (m) parsed = JSON.parse(m[0]);\n  }\n}\nreturn [{ json: { classification: parsed, raw: body, comment: $input.all()[0].json.comment, slug: $input.all()[0].json.slug } }];"
      },
      "name": "Parse AI JSON",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1060, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json[\"classification\"] && $json[\"classification\"].label ? $json[\"classification\"].label.toLowerCase() : '' }}",
              "operation": "equal",
              "value2": "legit"
            }
          ]
        }
      },
      "name": "IF is legit",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1320, 300]
    },
    {
