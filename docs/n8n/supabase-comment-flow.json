        "url": "={{ $env.WHATSAPP_API_URL || `https://graph.facebook.com/v16.0/${$env.WHATSAPP_PHONE_ID}/messages` }}",
        "jsonParameters": true,
        "options": {},
        "headerParametersJson": "{\"Authorization\":\"Bearer {{$env.WHATSAPP_ACCESS_TOKEN}}\",\"Content-Type\":\"application/json\"}",
        "bodyParametersJson": "{\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$env.ALERT_RECIPIENT_PHONE}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"preview_url\": false,\n    \"body\": \"Nuevo comentario anónimo en el artículo: {{ $json.slug }}\\nComentario: {{ $json.comment }}\\nIntención detectada: {{ $json.classification.intent }}\\nResumen: {{ $json.classification.summary }}\"\n  }\n}"
      },
